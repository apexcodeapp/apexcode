---
import { ServicesCardStack } from "@/components/ui/services-card-stack";
---

<section id="what-we-do" aria-labelledby="services-heading" class="relative pt-28 pb-48 bg-[#111111]">
  <div class="max-w-5xl mx-auto px-4">
    <h2
      id="services-heading"
      class="text-[28px] md:text-[40px] font-semibold leading-tight tracking-[-0.02em] text-white mb-14 text-center"
    >
      What We Build
    </h2>

    <div class="w-full" style="overflow: visible; position: relative;">
      <ServicesCardStack client:load />
    </div>
  </div>
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-24 bg-linear-to-b from-transparent to-[#0a0a0a]"></div>
</section>

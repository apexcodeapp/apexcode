---
import { ProcessCarousel } from "@/components/ui/process-carousel";
---

<section id="how-we-work" aria-labelledby="process-heading" class="relative py-28 bg-[#111111]">
  <div class="max-w-5xl mx-auto px-4">
    <h2
      id="process-heading"
      class="text-[28px] md:text-[40px] font-semibold leading-tight tracking-[-0.02em] text-white mb-14 text-center"
    >
      How We Work
    </h2>
  </div>
  <ProcessCarousel client:load />
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-24 bg-linear-to-b from-transparent to-[#0a0a0a]"></div>
</section>

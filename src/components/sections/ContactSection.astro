---
---

<section id="contact" aria-labelledby="contact-heading" class="py-30 bg-white">
  <div class="max-w-5xl mx-auto px-4 text-center">
    <h2
      id="contact-heading"
      class="text-[28px] md:text-[40px] font-semibold leading-tight tracking-[-0.02em] text-[#0a0a0a] mb-4"
    >
      Ready to Build?
    </h2>
    <p class="text-base font-normal leading-relaxed text-[#555555] mb-10 max-w-xl mx-auto">
      Tell us what you're working on. We'll get back to you within one business day.
    </p>
    <a
      href="mailto:hello@apexcode.dev"
      class="contact-cta"
    >
      hello@apexcode.dev
    </a>
  </div>
</section>

<style>
  .contact-cta {
    display: inline-block;
    background: #0a0a0a;
    color: #ffffff;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.8125rem 2rem;
    transition: background 150ms ease, transform 150ms ease;
  }
  .contact-cta:hover {
    background: #1a1a1a;
    transform: translateY(-1px);
  }
</style>

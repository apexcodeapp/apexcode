    <a href="/" class="text-base font-semibold text-text-primary">Apex Code</a>
    <nav class="hidden md:flex items-center gap-6">
      <a
        href="#services"
        class="text-sm font-normal text-text-muted hover:text-text-primary transition-colors duration-150 ease-in-out min-h-[44px] flex items-center"
